# DATABASE CONFIG
DATABASE_URL=mongodb://root:example@localhost:27017/
DB_NAME=ai_xray_master

# SMTP EMAIL CONFIG
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_email@gmail.com
SMTP_PASSWORD=your_smtp_app_password

# SECURITY CONFIG
JWT_SECRET_KEY=your_jwt_secret_key_here
REDIS_URL=redis://localhost:6379/0

# MULTI-TENANCY (subdomain routing)
# Apex domain that hospitals get a subdomain on (e.g. abc.localhost / abc.domain.com)
BASE_DOMAIN=localhost
TENANT_URL_SCHEME=http
TENANT_URL_PORT=5173

# HUGGING FACE HUB (cloud model & dataset storage)
# Create a free account at https://huggingface.co
# Get your token from: https://huggingface.co/settings/tokens (needs write access)
# Create a Dataset repo and a Model repo, then fill in the values below.
HF_TOKEN=your_hugging_face_token
HF_DATASET_REPO=jithinjz/xray-chest-pneumonia
HF_MODEL_REPO=jithinjz/xray-models

# GROQ LLM CONFIG
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
