# API Configuration
# Replace with your production backend URL (e.g., https://your-backend.railway.app)
VITE_API_BASE_URL=http://localhost:8000

# Multi-tenancy
# Apex domain that hospital tenants live under. Each registered hospital is
# reachable at <slug>.<VITE_BASE_DOMAIN>. In dev, "localhost" works because
# every modern browser resolves *.localhost → 127.0.0.1.
VITE_BASE_DOMAIN=localhost
